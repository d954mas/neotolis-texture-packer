{
  "schema": 2,
  "app_version": "0.2.0",
  "project_schema": 5,
  "verbs": {
    "inspect": 4,
    "validate": 2,
    "pack": 1,
    "new": {
      "apply": 1,
      "dry_run": 2
    },
    "add": {
      "apply": 1,
      "dry_run": 2
    },
    "remove": {
      "apply": 1,
      "dry_run": 2
    },
    "set": {
      "apply": 1,
      "dry_run": 2
    },
    "sprite": {
      "apply": 1,
      "dry_run": 2
    },
    "anim": {
      "apply": 1,
      "dry_run": 2,
      "list": 4
    },
