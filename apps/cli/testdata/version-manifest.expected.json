{
  "schema": 1,
  "app_version": "0.2.0",
  "project_schema": 5,
  "verbs": {
    "inspect": 4,
    "validate": 2,
    "pack": 1,
    "new": 1,
    "add": 1,
    "remove": 1,
    "set": 1,
    "sprite": 1,
    "anim": 1,
    "target": 1,
    "atlas": 1,
    "version": 1
  },
  "formats": {
    "json-neotolis": 1,
    "defold-tpinfo": "2.0"
  },
  "exporters": [
    {
      "id": "json-neotolis",
      "name": "JSON (neotolis, full fidelity)",
      "ext": "json",
      "caps": {
        "rotate90": true,
        "flips": true,
        "polygons": true,
        "pivot": true,
        "slice9": true,
        "multipage": true,
        "aliases": true
      }
    },
    {
      "id": "defold",
      "name": "Defold (.tpinfo + .tpatlas)",
      "ext": "tpinfo",
      "caps": {
        "rotate90": true,
        "flips": false,
        "polygons": true,
        "pivot": true,
        "slice9": false,
        "multipage": true,
        "aliases": true
      }
    }
  ]
}
