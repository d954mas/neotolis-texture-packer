    {
      "id": "defold",
      "name": "Defold (.tpinfo + .tpatlas)",
      "ext": "tpinfo",
      "caps": {
        "rotate90": true,
        "flips": false,
        "polygons": true,
        "pivot": true,
        "slice9": false,
        "multipage": true,
        "aliases": true
      }
    }
