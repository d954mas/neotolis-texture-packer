{
    // Owner workflow target: F5 -> ntpacker-gui, open a .ntpacker_project,
    // see the packed atlas, export. The GUI binary lands in Phase 6 (needs
    // 1b tp_pack -> 2 exporters -> 3 project file first); until then run
    // tests via the "test (native-debug)" task (Ctrl+Shift+P -> Run Task).
    "version": "0.2.0",
    "configurations": [
        {
            "name": "ntpacker-gui (Phase 6 - binary does not exist yet)",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/apps/gui/native-debug/ntpacker-gui.exe",
            "args": ["${workspaceFolder}/examples/demo.ntpacker_project"],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "preLaunchTask": "build (native-debug)"
        }
    ]
}
