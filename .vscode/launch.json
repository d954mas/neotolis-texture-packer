{
    // Owner workflow target: F5 -> the normal interactive GUI. The pre-launch
    // task always reconfigures native-debug/native-release, which clears any
    // sticky GUI self-test flags from a different preset before the executable
    // is built and launched.
    "version": "0.2.0",
    "configurations": [
        {
            "name": "ntpacker-gui (debug)",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/apps/gui/native-debug/ntpacker-gui.exe",
            "args": [],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "preLaunchTask": "build (native-debug)"
        },
        {
            "name": "ntpacker-gui (release)",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/apps/gui/native-release/ntpacker-gui.exe",
            "args": [],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "preLaunchTask": "build (native-release)"
        }
    ]
}
